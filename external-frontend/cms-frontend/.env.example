# CMS frontend → API gateway (api-backend) mounts CMS at /api/cms
# Origin of api-backend (no trailing slash)
VITE_API_ORIGIN=http://localhost:3000

# Required: API token (sk_...) from API system Admin → API Tokens (system: cms)
VITE_CMS_API_TOKEN=sk_xxx

# Legacy: full URL to old path; only used to derive origin if VITE_API_ORIGIN is unset
# VITE_API_BASE_URL=http://localhost:3000/api/cms
