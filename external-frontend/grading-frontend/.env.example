# API backend origin (for fetching systems). Grading base URL is derived from GET /api/external/systems.
VITE_API_ORIGIN=http://localhost:3000
# Optional: override full Grading API base URL (e.g. http://localhost:3000/api/grading)
# VITE_API_URL=http://localhost:3000/api/grading

# Grading API token (required when using api-backend). Create in api-backend Admin > API tokens for system "grading".
VITE_GRADING_API_TOKEN=sk_xxx

# Firebase (must match your Grading Firebase project for login)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# VITE_FIREBASE_MEASUREMENT_ID=G-xxxxx
