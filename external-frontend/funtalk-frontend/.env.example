# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Required: Funtalk API token (sk_xxx). Create in api-backend Admin > API tokens for the Funtalk system.
# Without this, the Funtalk frontend will not fetch any data. Get your token from the API system only.
VITE_FUNTALK_API_TOKEN=sk_xxx

# Firebase Configuration (must match Funtalk backend project, e.g. funtalk-77c3d)
# Get these from Firebase Console → Project Settings → General → Your apps (Web app)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=funtalk-77c3d
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

