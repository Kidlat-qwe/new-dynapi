# PostgreSQL (match your pgAdmin connection)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=new_api_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Neon / cloud Postgres: SSL is auto-enabled when the host looks like Neon (or set explicitly).
# Local Postgres without TLS: DB_SSL=false
# DB_SSL=true

# Server
PORT=3000

# Startup: default is quiet (two-line banner). Set to 1 for full DB/Firebase/S3 logs.
# VERBOSE_STARTUP=1

# CMS/Funtalk DB query logging (off by default). Set to 1 to log each SQL query.
# DEBUG_DB_QUERIES=1

# CORS: comma-separated browser origins (credentials mode). Defaults include 5173 and 5174.
# Override if your Vite port differs, e.g.:
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Firebase Admin (required for /api/users/me, /api/users/sync, /api/admin/*).
# Without it you get 401. Place the service account JSON in src/config/ or set path:
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your-project-firebase-adminsdk-xxxxx.json
